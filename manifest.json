{
  "manifest_version": 3,
  "name": "招聘沟通记录统计器",
  "version": "1.27.0",
  "description": "轻松更新沟通记录。当前支持 BOSS直聘 zhipin.com、猎聘 liepin.com，支持表格、CSV 和 JSON 导出。",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.liepin.com/*",
    "https://*.zhipin.com/*",
    "https://api-c.liepin.com/*"
  ],
  "action": {
    "default_title": "统计招聘沟通记录",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.liepin.com/*",
        "https://*.zhipin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "boss-hook.js"
      ],
      "matches": [
        "https://*.zhipin.com/*"
      ]
    }
  ]
}
